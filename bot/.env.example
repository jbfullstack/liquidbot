# ── RPC (WebSocket REQUIRED for block subscription) ──
ARBITRUM_RPC_API_KEY=YOUR_KEY
ARBITRUM_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Wallet ──
PRIVATE_KEY=0x_your_hot_wallet_private_key
COLD_WALLET=0x_your_ledger_address

# ── Contract (set after deploy) ──
CONTRACT_ADDRESS=0x_deployed_flash_liquidator

# ── Tuning ──
MIN_PROFIT_USD=2
MAX_GAS_GWEI=1
ETH_KEEP=0.005
ETH_SWEEP_KEEP=0.07
HF_THRESHOLD=1.05
# Blocs à scanner au premier démarrage (pas d'index sauvegardé).
# Arbitrum ~0.25s/bloc → 4_000_000 ≈ 14 jours. Min: 2_500_000 (~1 sem), Max: 20_000_000 (~58 j).
SCAN_LOOKBACK_BLOCKS=4000000

# ── Protocols ──
# Comma-separated list of protocol IDs to enable on first start (if no protocols.json).
# Known IDs: aave_v3, radiant_v2, compound_v3, silo
# Only Active protocols can liquidate; Planned = metadata only, toggle via /enable.
ENABLED_PROTOCOLS=aave_v3

# ── Logging ──
RUST_LOG=info

# ── Systemd (pour /restart et /logs depuis Telegram) ──
# Nom du service tel que dans /etc/systemd/system/<SERVICE_NAME>.service
SERVICE_NAME=liquidator

# ── Telegram (push notifications sur ton tel) ──
# 1. Message @BotFather sur Telegram → /newbot → copie le token
# 2. Message ton bot, puis visite:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    → cherche "chat":{"id": XXXXXX} → c'est ton chat_id
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=987654321
SERVICE_NAME=liquidator
